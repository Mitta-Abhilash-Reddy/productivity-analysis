{
  "name": "tracker-app",
  "version": "2.0.1",
  "description": "Remote Employee Productivity Monitor — Production Ready",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
 "build": {
  "appId": "com.company.worktracker",
  "productName": "WorkTracker",

  "asar": true,

  "asarUnpack": [
    "**/*.node",
    "**/node_modules/screenshot-desktop/**/*"
  ],

  "files": [
    "**/*"
  ],

  "mac": {
    "category": "public.app-category.productivity",
    "target": "dmg"
  },
  "win": {
    "target": "nsis"
  },
  "linux": {
    "target": "AppImage"
  }
},
  "dependencies": {
    "active-win": "^8.1.0",
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "screenshot-desktop": "^1.12.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
